# FreshKeeper Backend — Environment Variables
# Copy to .env and fill in your values.

# ── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=freshkeeper
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ── Server ─────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3001

# ── AI ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
